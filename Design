body {
  font-family: Arial, sans-serif;
  text-align: center;
  background: linear-gradient(to bottom, #e3f2fd, #ffffff);
}

h1 {
  color: #333;
}

button {
  padding: 12px 20px;
  font-size: 18px;
  border-radius: 12px;
  border: none;
  background: #4caf50;
  color: white;
}

button:hover {
  background: #2e7d32;
}

.card {
  margin: 20px auto;
  padding: 20px;
  width: 80%;
  border-radius: 20px;
  background: #ffffff;
  box-shadow: 0 4px 10px rgba(0,0,0,0.1);
}
